                  "fontSize": 36,
                  "fontWeight": "800"
                },
                {
                  "type": "text",
                  "id": "0lKam",
                  "name": "storyP1",
                  "fill": "$--muted-foreground",
                  "content": "After 15 years in the roofing industry, our founder saw the same broken pattern everywhere: homeowners forced to sit through aggressive sales pitches, mystery pricing that changed based on the salesperson, and zero visibility once the contract was signed.",
                  "lineHeight": 1.7,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "O35GN",
                  "name": "storyP2",
                  "fill": "$--muted-foreground",
                  "content": "Results Roofing was built to fix that. We use satellite technology to measure your roof instantly, publish our pricing openly, and give every customer a real-time project portal. No games, no gimmicks — just a better way to replace your roof.",
                  "lineHeight": 1.7,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
