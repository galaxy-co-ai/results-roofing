            {
              "type": "text",
              "id": "aTBMm",
              "name": "term2",
              "fill": "$text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "2. MATERIALS — All materials will be as specified in the selected package. Equivalent substitutions may be made with homeowner approval if specific products are unavailable.",
              "lineHeight": 1.6,
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "m5NZy",
              "name": "term3",
              "fill": "$text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "3. WARRANTY — Work is covered by the manufacturer warranty associated with the selected package and a 5-year workmanship warranty from Results Roofing LLC.",
              "lineHeight": 1.6,
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "5Iv57",
              "name": "term4",
              "fill": "$text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "4. PAYMENT — Deposit is due at signing. Remaining balance is due upon completion of work. Payments are processed securely via Stripe.",
              "lineHeight": 1.6,
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "9PI8R",
              "name": "term5",
              "fill": "$text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "5. CANCELLATION — Homeowner may cancel this agreement within 3 business days of signing for a full refund of the deposit.",
              "lineHeight": 1.6,
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "normal"
            },
