                  ]
                },
                {
                  "type": "frame",
                  "id": "vgEMu",
                  "name": "tocItem6",
                  "width": "fill_container",
                  "cornerRadius": 6,
                  "padding": [
                    6,
                    12
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "lBFdB",
                      "name": "tocItem6Txt",
                      "fill": "#64748b",
                      "content": "The Bottom Line",
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            },
            {
              "type": "frame",
              "id": "uxmFc",
              "name": "Article Body",
              "width": 680,
              "layout": "vertical",
              "gap": 36,
              "children": [
                {
                  "type": "frame",
                  "id": "Al4q2",
                  "name": "Section - Intro",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 16,
                  "children": [
                    {
                      "type": "text",
                      "id": "MAFfH",
                      "name": "sec1P1",
                      "fill": "#374151",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "If you've ever gotten a roofing quote the traditional way, you know the drill: schedule an appointment, wait for someone to show up, watch them climb your roof with a tape measure, then wait another few days for an email with a number that may or may not make sense.",
                      "lineHeight": 1.75,
                      "fontFamily": "Inter",
                      "fontSize": 17,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "OGZDw",
                      "name": "sec1P2",
                      "fill": "#374151",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "We thought there had to be a better way. Turns out, there is — and it involves satellites.",
                      "lineHeight": 1.75,
                      "fontFamily": "Inter",
                      "fontSize": 17,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "V3hVC",
                  "name": "Section - How It Works",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 14,
                  "children": [
                    {
                      "type": "text",
                      "id": "dCi2X",
                      "name": "sec2H",
                      "fill": "#1a1a2e",
                      "content": "How Satellite Measurement Actually Works",
                      "fontFamily": "Sora",
                      "fontSize": 22,
                      "fontWeight": "700",
                      "letterSpacing": -0.3
                    },
                    {
                      "type": "text",
                      "id": "8ARN0",
                      "name": "sec2P1",
                      "fill": "#374151",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Google's Solar API uses high-resolution aerial imagery — the same kind that powers Google Maps — combined with machine learning to create a detailed 3D model of your roof. In under 2 seconds, it calculates total square footage, pitch angle, number of facets, and structural complexity.",
                      "lineHeight": 1.75,
                      "fontFamily": "Inter",
                      "fontSize": 17,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "vmFgW",
                      "name": "sec2P2",
                      "fill": "#374151",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "When you enter your address on our site, we send it to the Solar API, get back the measurements, and use them to generate real pricing based on your actual roof — not a guess, not an average, your roof.",
                      "lineHeight": 1.75,
                      "fontFamily": "Inter",
                      "fontSize": 17,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "9T35H",
                  "name": "Section - Accuracy",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 14,
                  "children": [
                    {
                      "type": "text",
                      "id": "cbhrB",
                      "name": "sec3H",
                      "fill": "#1a1a2e",
                      "content": "Is It Actually Accurate?",
                      "fontFamily": "Sora",
                      "fontSize": 22,
                      "fontWeight": "700",
                      "letterSpacing": -0.3
                    },
                    {
                      "type": "text",
                      "id": "t3xHm",
                      "name": "sec3P1",
                      "fill": "#374151",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Fair question. The short answer: yes, within 2-5% of a manual measurement for most residential roofs. Google's imagery is refreshed regularly and the ML models have been trained on millions of buildings.",
                      "lineHeight": 1.75,
                      "fontFamily": "Inter",
                      "fontSize": 17,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "Rxwny",
                  "name": "Mid-Article CTA",
                  "width": "fill_container",
                  "fill": "#eef1ff",
                  "cornerRadius": 12,
                  "stroke": {
                    "align": "inside",
                    "thickness": 1,
                    "fill": "#4361ee33"
                  },
                  "layout": "vertical",
                  "gap": 6,
                  "padding": 24,
                  "children": [
                    {
                      "type": "text",
                      "id": "vsUh6",
                      "name": "midCtaTitle",
                      "fill": "#1a1a2e",
                      "content": "🛰️ Want to see your actual roof measurements?",
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "h9Kg0",
                      "name": "midCtaSub",
                      "fill": "#64748b",
                      "content": "Enter your address and get satellite-verified pricing in under 2 minutes.",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "8HESn",
                      "name": "midCtaBtn",
                      "fill": "#4361ee",
                      "cornerRadius": 8,
                      "padding": [
                        12,
                        20
                      ],
                      "alignItems": "center",
                      "children": [
                        {
                          "type": "text",
                          "id": "HyHy5",
                          "name": "midCtaBtnTxt",
                          "fill": "#FFFFFF",
                          "content": "Get My Instant Quote →",
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "600"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "YE7cc",
                  "name": "Section - What We Measure",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 14,
                  "children": [
                    {
                      "type": "text",
                      "id": "PhDuH",
                      "name": "sec4H",
                      "fill": "#1a1a2e",
                      "content": "What We Actually Measure",
                      "fontFamily": "Sora",
                      "fontSize": 22,
                      "fontWeight": "700",
                      "letterSpacing": -0.3
                    },
                    {
                      "type": "text",
                      "id": "MGa3c",
                      "name": "sec4P",
                      "fill": "#374151",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "When the satellite scans your roof, we capture four key data points: total square footage (the actual surface area, not your home's footprint), roof pitch (the steepness — steeper roofs cost more to install), number of facets (each plane of your roof), and overall complexity score. These four numbers are what drive your quote.",
                      "lineHeight": 1.75,
                      "fontFamily": "Inter",
                      "fontSize": 17,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "s2eqW",
                  "name": "Section - Privacy",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 14,
                  "children": [
                    {
                      "type": "text",
                      "id": "1ATUL",
                      "name": "sec5H",
                      "fill": "#1a1a2e",
                      "content": "Privacy & Common Concerns",
                      "fontFamily": "Sora",
                      "fontSize": 22,
                      "fontWeight": "700",
                      "letterSpacing": -0.3
                    },
                    {
                      "type": "text",
                      "id": "lJoWI",
                      "name": "sec5P",
                      "fill": "#374151",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "We get it — \"satellite measurement\" sounds a little Big Brother. But this is the same imagery you can already see on Google Maps. We don't use drones, we don't take new photos, and we don't capture anything inside your home. The data we receive is purely structural: roof dimensions and geometry. Nothing else.",
                      "lineHeight": 1.75,
                      "fontFamily": "Inter",
                      "fontSize": 17,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "pbs8F",
                  "name": "Section - Bottom Line",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 14,
                  "children": [
                    {
                      "type": "text",
                      "id": "To7wl",
                      "name": "sec6H",
                      "fill": "#1a1a2e",
                      "content": "The Bottom Line",
                      "fontFamily": "Sora",
                      "fontSize": 22,
                      "fontWeight": "700",
                      "letterSpacing": -0.3
                    },
                    {
                      "type": "text",
                      "id": "fyHQD",
                      "name": "sec6P",
                      "fill": "#374151",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Satellite roof measurement isn't the future — it's the present. It means you can get a real, accurate roofing quote from your couch in under two minutes. No strangers on your roof, no awkward sales pitch, no waiting. Just your actual measurements, your actual prices, and your decision on your timeline.",
                      "lineHeight": 1.75,
                      "fontFamily": "Inter",
                      "fontSize": 17,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "v7xaC",
                  "name": "divider",
                  "width": "fill_container",
                  "height": 1,
                  "fill": "#e8ecf1"
                },
